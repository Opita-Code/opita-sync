{
  "name": "opita-sync-assets-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "tokens:build": "node ./scripts/build-tokens.mjs",
    "svg:build": "node ./scripts/optimize-svg.mjs",
    "storybook:dev": "storybook dev -p 6006 -c ./storybook/.storybook",
    "storybook:build": "storybook build -c ./storybook/.storybook"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-docs": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "style-dictionary": "^4.1.0",
    "svgo": "^3.3.2"
  }
}
